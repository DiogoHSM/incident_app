DATABASE_URL=postgres://incident:incident@localhost:5433/incident_app

# Comma-separated emails that get the admin role on first sign-in.
# In dev mode, sign-in with any email here promotes you to admin.
ADMIN_EMAILS=dev-admin@local

# NextAuth v5
AUTH_SECRET=replace-me-32-bytes-base64-or-longer-string
AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Auth provider — pick ONE.
#   dev    → 100% offline. A Credentials form on /signin accepts any email; no
#            external IdP, no internet required. Use ADMIN_EMAILS to choose
#            which addresses get the admin role.
#   google → Google OIDC. Requires AUTH_GOOGLE_CLIENT_ID and AUTH_GOOGLE_CLIENT_SECRET.
# ---------------------------------------------------------------------------
AUTH_PROVIDER=dev

# Only required when AUTH_PROVIDER=google.
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# AES-256-GCM key for encrypting webhook source HMAC secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# (The placeholder below is 32 zero bytes — fine for local dev, NOT for production.)
WEBHOOK_SECRET_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
